databases/cpn60/*.fasta
databases/cpn60/*.qza
databases/pheS/*.fasta
databases/pheS/*.qza
databases/ITS/*.fasta
databases/ITS/*.qza
databases/16S/*.fasta
databases/16S/*.qza
validation/public_data/*.fastq*
validation/public_data/*.sra

